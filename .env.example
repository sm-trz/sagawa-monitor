# ============================================================
# sagawa-monitor / .env.example
# ローカル開発用の環境変数サンプル
# このファイルをコピーして .env を作成してください
# .env は .gitignore に追加し、リポジトリにコミットしないこと！
# ============================================================

# ── Google Sheets ─────────────────────────────────────────────────────────────
# スプレッドシートの URL から取得
# 例: https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
SPREADSHEET_ID=your_spreadsheet_id_here

# シート名（デフォルト: 返品管理）
SHEET_NAME=返品管理

# ── Google 認証 ───────────────────────────────────────────────────────────────
# ローカル開発時: サービスアカウントキー JSON ファイルのパス
# Cloud Run 上: Application Default Credentials (ADC) を使用するため不要
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ── アプリ設定 ────────────────────────────────────────────────────────────────
# サーバーポート（Cloud Run は 8080 固定）
PORT=8080

# 起動直後に監視処理を実行するか（true / false）
RUN_ON_STARTUP=false

# ログレベル（debug / info / warn / error）
LOG_LEVEL=info
